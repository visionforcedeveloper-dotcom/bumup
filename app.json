{
  "expo": {
    "name": "BumUp",
    "slug": "bumup",
    "version": "1.5.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "jsEngine": "hermes",
    "icon": "./Assets/logo/logo-png.png",
    "splash": {
      "image": "./Assets/logo/logo-png.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0B0E"
    },
    "plugins": [
      "./plugins/withMainApplication",
      "./plugins/withGradleProperties",
      "./plugins/withExtractNativeLibs"
    ],
    "android": {
      "package": "com.bumup.app",
      "versionCode": 54,
      "adaptiveIcon": {
        "foregroundImage": "./Assets/logo/logo-png.png",
        "backgroundColor": "#0D0B0E"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "owner": "visionforce6",
    "extra": {
      "eas": {
        "projectId": "e25f5ce1-4d8a-42cb-b650-796029fdf63b"
      }
    }
  }
}
