{
  "expo": {
    "name": "BumUp",
    "slug": "bumup",
    "version": "1.4.7",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "jsEngine": "hermes",
    "icon": "./Assets/logo/logo-png.png",
    "splash": {
      "image": "./Assets/logo/logo-png.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0B0E"
    },
    "plugins": [
      "./plugins/withTargetSdk35",
      "./plugins/withMainApplication",
      "./plugins/withGradleProperties",
      "./plugins/withExtractNativeLibs"
    ],
    "android": {
      "package": "com.bumup.app",
      "versionCode": 44,
      "adaptiveIcon": {
        "foregroundImage": "./Assets/logo/logo-png.png",
        "backgroundColor": "#0D0B0E"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "owner": "visionforce5",
    "extra": {
      "eas": {
        "projectId": "4dfa0e27-f395-43ac-8d5e-807342f39c7b"
      }
    }
  }
}
